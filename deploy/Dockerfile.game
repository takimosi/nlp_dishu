FROM python:3.10-slim

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

WORKDIR /app/game

COPY deploy/requirements-game.txt /tmp/requirements.txt
RUN pip install \
    --no-cache-dir \
    --index-url https://mirrors.aliyun.com/pypi/simple/ \
    --trusted-host mirrors.aliyun.com \
    --timeout 120 \
    --retries 5 \
    -r /tmp/requirements.txt

COPY game /app/game

EXPOSE 5001
CMD ["python", "chain_server.py"]
